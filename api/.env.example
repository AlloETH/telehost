# Database (same as Next.js app)
DATABASE_URL=postgresql://telehost:telehost@localhost:5432/telehost

# Secrets (same as Next.js app)
JWT_SECRET=
ENCRYPTION_SECRET=

# Coolify
COOLIFY_API_URL=https://server.tokn.deal/api/v1
COOLIFY_API_TOKEN=
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
COOLIFY_ENVIRONMENT_NAME=production
COOLIFY_DESTINATION_UUID=

# Agent config
AGENT_BASE_DOMAIN=  # e.g. server.tokn.deal — instances get {slug}.server.tokn.deal

# TON Payments
TON_SERVICE_WALLET_ADDRESS=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Public (frontend URL for TMA links and container callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# CORS (comma-separated frontend origins)
CORS_ORIGIN=http://localhost:3001

# Port
PORT=3000
