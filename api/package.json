    "dev": "ts-node --transpile-only -r reflect-metadata src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
