    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.2",
    "postgres": "^3.4.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tweetnacl": "^1.0.3",
    "drizzle-kit": "^0.31.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
